{
  "manifest": {
    "publishingInformation": {
      "locales": {
        "en-US": {
          "summary": "Ambient Relaxation Chill Music",
          "examplePhrases": [
            "Alexa, open Chill Music",
            "Alexa, play Chill Music",
            "Alexa, ask Chill Music to play"
          ],
          "name": "Chill Music",
          "description": "A relaxing ambient music skill featuring AudioPlayer and APL visuals."
        }
      },
      "isAvailableWorldwide": true,
      "testingInstructions": "Say 'Alexa, open Chill Music' to start.",
      "category": "GAMES",
      "distributionCountries": []
    },
    "apis": {
      "custom": {
        "endpoint": {
          "sourceDir": "lambda",
          "uri": "ask-custom-chillmusic-default"
        },
        "interfaces": [
          {
            "type": "AUDIO_PLAYER"
          },
          {
            "type": "ALEXA_PRESENTATION_APL",
            "supportedViewports": [
              {
                "mode": "HUB",
                "shape": "ROUND",
                "minWidth": 480,
                "maxWidth": 480,
                "minHeight": 480,
                "maxHeight": 480
              },
              {
                "mode": "HUB",
                "shape": "RECTANGLE",
                "minWidth": 1024,
                "maxWidth": 1024,
                "minHeight": 600,
                "maxHeight": 600
              },
              {
                "mode": "HUB",
                "shape": "RECTANGLE",
                "minWidth": 1280,
                "maxWidth": 1280,
                "minHeight": 800,
                "maxHeight": 800
              },
              {
                "mode": "TV",
                "shape": "RECTANGLE",
                "minWidth": 1920,
                "maxWidth": 1920,
                "minHeight": 1080,
                "maxHeight": 1080
              }
            ]
          }
        ]
      }
    },
    "manifestVersion": "1.0",
    "privacyAndCompliance": {
      "allowsPurchases": false,
      "usesPersonalInfo": false,
      "isChildDirected": false,
      "isExportCompliant": true,
      "containsAds": false
    }
  }
}