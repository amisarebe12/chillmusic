{
  "type": "APL",
  "version": "2023.2",
  "document": {
    "mainTemplate": {
      "parameters": [
        "payload"
      ],
      "item": {
        "type": "Container",
        "width": "100%",
        "height": "100%",
        "items": [
          {
            "type": "Image",
            "source": "${payload.musicData.backgroundUrl}",
            "width": "100%",
            "height": "100%",
            "position": "absolute",
            "scale": "best-fill",
            "filters": [
              {
                "type": "Blur",
                "radius": 20
              }
            ]
          },
          {
            "type": "Container",
            "width": "100%",
            "height": "100%",
            "justifyContent": "center",
            "alignItems": "center",
            "items": [
              {
                "type": "Image",
                "source": "${payload.musicData.logoUrl}",
                "width": "40vw",
                "height": "40vw",
                "borderRadius": "20vw"
              },
              {
                "type": "Text",
                "text": "${payload.musicData.title}",
                "fontSize": "50dp",
                "color": "#FFFFFF",
                "fontWeight": "bold",
                "paddingTop": "20dp"
              },
              {
                "type": "Text",
                "text": "${payload.musicData.subtitle}",
                "fontSize": "30dp",
                "color": "#E0E0E0",
                "paddingTop": "10dp"
              }
            ]
          }
        ]
      }
    }
  }
}